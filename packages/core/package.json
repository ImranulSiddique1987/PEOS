{
  "name": "@peos/core",
  "version": "0.1.0",
  "private": true,
  "description": "Core runtime library for the PEOS (Product Engineering Operating System) monorepo.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
